# Groq API Key - Replace with your actual Groq API key
# You can get one from Groq Console: https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# Gmail SMTP Configuration for Verification Emails
# Go to your Google Account Settings -> Security -> App passwords to generate a 16-digit password.
SMTP_EMAIL=your_gmail_sender@gmail.com
SMTP_PASSWORD=your_16_digit_gmail_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
